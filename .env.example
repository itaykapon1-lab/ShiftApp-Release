# ===========================================
# ShiftApp Environment Configuration
# ===========================================
# Copy this file to .env and customize values.
# Default values support local SQLite development.

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# For local development (SQLite - default):
# DATABASE_URL=sqlite:///scheduler.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://shiftapp:your-password@localhost:5432/shiftapp

# Connection pool settings (PostgreSQL only)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5

# ===========================================
# SECURITY
# ===========================================
# CRITICAL: Change this in production!
SECRET_KEY=dev-secret-key-change-in-production

# ===========================================
# CORS CONFIGURATION
# ===========================================
# Comma-separated list of allowed origins
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================================
# FILE UPLOAD LIMITS
# ===========================================
MAX_FILE_SIZE_MB=10

# ===========================================
# SOLVER CONFIGURATION
# ===========================================
# Number of parallel solver processes
SOLVER_MAX_WORKERS=4
