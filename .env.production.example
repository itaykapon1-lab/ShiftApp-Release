# ===========================================
# ShiftApp — Production Environment Variables
# ===========================================
# Copy to .env and fill in all required values
# before running: docker compose up -d
#
# Required values are marked with CHANGE_ME.

# ===========================================
# DOMAIN (used by Caddy for auto-HTTPS)
# ===========================================
DOMAIN=shiftapp.example.com

# ===========================================
# DATABASE
# ===========================================
# Used internally by docker-compose to configure
# both the PostgreSQL container and the API connection.
DB_PASSWORD=CHANGE_ME

# Connection pool tuning (defaults are fine for most setups)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=5
# DB_POOL_RECYCLE=1800
# DB_POOL_TIMEOUT=30

# ===========================================
# SECURITY
# ===========================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME
ENVIRONMENT=production

# ===========================================
# CORS
# ===========================================
# With Caddy as unified proxy, frontend and API share
# the same origin — use your domain here.
CORS_ORIGINS=https://shiftapp.example.com

# ===========================================
# FRONTEND
# ===========================================
# Relative path — works because Caddy proxies both
# frontend and API on the same origin.
VITE_API_BASE=/api/v1

# ===========================================
# SOLVER
# ===========================================
# Keep at 2 to leave CPU headroom for solver subprocesses
# on a 4-OCPU ARM64 instance.
SOLVER_MAX_WORKERS=2

# ===========================================
# GUNICORN
# ===========================================
# Number of Gunicorn workers (default: 2)
GUNICORN_WORKERS=2

# ===========================================
# FILE UPLOADS
# ===========================================
MAX_FILE_SIZE_MB=10

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO

# ===========================================
# REDIS (optional)
# ===========================================
# Enables cross-worker rate limit storage.
# Without this, each Gunicorn worker tracks limits independently.
# REDIS_URL=redis://redis:6379/0
